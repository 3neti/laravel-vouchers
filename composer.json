{
    "name": "3neti/laravel-vouchers",
    "description": "Voucher system for Laravel 10+",
    "license": "MIT",
    "keywords": [
        "coupon",
        "discount",
        "laravel",
        "voucher"
    ],
    "type": "library",
    "authors": [
        {
            "name": "Frederik Sauer",
            "email": "fritten.keez@gmail.com"
        },
        {
            "name": "Lester Hurtado",
            "email": "lester@hurtado.ph"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/collections": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/config": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.20",
        "nesbot/carbon": "^2.63|^3.8.4",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.2|^3.0|^4.0"
    },
    "config": {
        "allow-plugins": {
            "kylekatarnls/update-helper": false,
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "FrittenKeeZ\\Vouchers\\": "src"
        }
    },
    "autoload-dev": {
        "files": [
            "tests/Models/Fake.php"
        ],
        "psr-4": {
            "FrittenKeeZ\\Vouchers\\Tests\\": "tests",
            "FrittenKeeZ\\Vouchers\\Tests\\Database\\Factories\\": "tests/database/factories"
        }
    },
    "scripts": {
        "pint": "pint",
        "test": "pest --parallel",
        "test-coverage": "pest --parallel --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "FrittenKeeZ\\Vouchers\\VouchersServiceProvider"
            ],
            "aliases": {
                "Vouchers": "FrittenKeeZ\\Vouchers\\Facades\\Vouchers"
            }
        }
    }
}
